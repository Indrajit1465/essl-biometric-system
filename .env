HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=mysql+aiomysql://att_user:root@localhost:3306/attendance_db

# MySQL (production) — also run: pip install aiomysql PyMySQL
# DATABASE_URL=mysql+aiomysql://attendance_user:yourpassword@localhost:3306/attendance_db

# ── Security ──────────────────────────────────────────────────────────────────
API_SECRET_KEY=12345SECRET

# ── Device ────────────────────────────────────────────────────────────────────
ALLOWED_DEVICE_SERIALS=["CQQC232460300"]
DEVICE_TIMEZONE=5.5
MAX_CLOCK_DRIFT_SECONDS=300
ADMS_TRANS_INTERVAL=1

# ── Pull mode ─────────────────────────────────────────────────────────────────
PULL_DEVICE_PORT=4370
PULL_DEVICE_TIMEOUT=10
PULL_CLEAR_AFTER_FETCH=False

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DEVICE_REQUESTS=true
