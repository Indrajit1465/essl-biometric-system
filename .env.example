HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL (production):
DATABASE_URL=mysql+aiomysql://attendance_user:YOUR_PASSWORD@localhost:3306/attendance_db
# SQLite (dev only — install aiosqlite):
# DATABASE_URL=sqlite+aiosqlite:///./attendance.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-in-production

# ── CORS — comma-separated allowed origins ────────────────────────────────────
CORS_ORIGINS=http://localhost:8000

# ── Device ────────────────────────────────────────────────────────────────────
ALLOWED_DEVICE_SERIALS=[]
DEVICE_TIMEZONE=5.5
MAX_CLOCK_DRIFT_SECONDS=300
ADMS_TRANS_INTERVAL=1

# ── Pull mode ─────────────────────────────────────────────────────────────────
PULL_DEVICE_PORT=4370
PULL_DEVICE_TIMEOUT=10
PULL_CLEAR_AFTER_FETCH=False

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DEVICE_REQUESTS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120